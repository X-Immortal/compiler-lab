const int A = (0x10 - 014) / 2;

int evaluate(int seed) {
    int score = 0;
    if (5 > 4 > 0) {
        score = score + 1;
    }
    if (5 > 4 < 0) {
        score = score + 1;
    }
    if (2 < 1 == 0) {
        score = score + 1;
    }
    if (3 == 3 != 0) {
        score = score + 1;
    }
    if (!seed < A) {
        score = score + 1;
    }
    if (seed - 9 || A && 1) {
        score = score + 10;
    }
    return score;
}

int main() {
    int seed = 3 * (A + 1);
    return evaluate(seed) + seed;
}
