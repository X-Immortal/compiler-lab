const int stride = 1;

int twice(int x) {
  return x + x;
}

int score(int row[]) {
  int i = 0;
  int acc = 0;
  while (i < 2) {
    acc = acc + row[i] * (i + 1);
    i = i + 1;
  }
  return acc;
}

int choose(int flag, int a, int b) {
  if (flag && !0) {
    return a;
  } else {
    return b;
  }
}

int main() {
  int twice = 1;
  int matrix[3][2] = {{1, 2}, {3, 4}, {5, 6}};
  int backup[5] = {7, 8, 9, 10, 11};
  int ans = 0;
  int i = 0;
  while (i < 3) {
    matrix[i] = backup;
    {
      const int flag = 1;
      int local = choose(flag, score(matrix[i]), -score(matrix[i]));
      ans = ans + local;
    }
    i = stride + twice + i;
  }
  if (ans > 0 && choose(1, ans, 0)) {
    return ans + score(matrix[1]);
  } else {
    return score(matrix[2]);
  }
}
